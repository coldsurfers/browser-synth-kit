{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "synth-kit-demo",
  "compatibility_date": "2026-07-09",
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "synth-kit.coldsurf.io",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
