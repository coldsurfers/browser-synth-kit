{
  "name": "browser-synth-kit",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @coldsurf/synth-kit (color-blind Web Audio synthesis engines) and its browser demo playground.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coldsurfers/browser-synth-kit.git"
  },
  "scripts": {
    "build": "pnpm --filter @coldsurf/synth-kit build",
    "check:type": "pnpm -r check:type",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "dev": "pnpm --filter demo dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
